-- 🎯 DANH SÁCH RƯƠNG
local chestNames = {
	"Silver Chest",
	"Gold Chest",
	"Diamond Chest"
}

-- tìm rương random
local function getRandomChest()
	local list = {}
	
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("Model") and table.find(chestNames, v.Name) then
			if v:FindFirstChild("HumanoidRootPart") then
				table.insert(list, v)
			end
		end
	end
	
	if #list > 0 then
		return list[math.random(1,#list)]
	end
end

-- 💰 UPDATE BELI
task.spawn(function()
	while true do
		task.wait(1)
		local current = getBeli()
		beliLabel.Text = "Beli: "..tostring(current - startBeli)
	end
end)

