-- 🚀 FARM LOOP
task.spawn(function()
	while true do
		task.wait(0.2)
		
		if not FARM then continue end
		
		local char = player.Character
		if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
		
		local root = char.HumanoidRootPart
		local chest = getRandomChest()
		
		if chest then
			root.CFrame = chest.HumanoidRootPart.CFrame + Vector3.new(0,3,0)
		end
	end
end)

-- TOGGLE
